# ─────────────────────────────────────
# Email Notification Configuration
# ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is gitignored and should NEVER be committed.

# Gmail SMTP (recommended: use an App Password, not your real password)
# To create an App Password: myaccount.google.com → Security → 2-Step → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16char_app_password

# Where to send the daily summary report
NOTIFY_EMAIL=your_gmail@gmail.com

# Timezone for the container (affects cron scheduling)
TZ=Asia/Tokyo
